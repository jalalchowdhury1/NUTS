{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "NutsAlgoS3ReadWrite",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::nuts-algo-data/*"
    },
    {
      "Sid": "NutsAlgoS3List",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::nuts-algo-data"
    }
  ]
}
